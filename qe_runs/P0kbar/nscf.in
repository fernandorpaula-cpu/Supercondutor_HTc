      ! nscf.in — Hg-1212, P = 0.0 GPa (0 kbar)
      ! Dense k-mesh for accurate DOS and Fermi-surface mapping
      !
      &CONTROL
        calculation   = 'nscf'
        restart_mode  = 'from_scratch'
        prefix        = 'Hg1212_P0kbar'
        outdir        = './out/'
        pseudo_dir    = '../../data/pseudopotentials/'  ! [PLACEHOLDER]
        verbosity     = 'high'
      /
      &SYSTEM
        ibrav         = 6           ! [PLACEHOLDER — use CELL_PARAMETERS from SCF]
        celldm(1)     = 7.290563
        celldm(3)     = 4.069466
        nat           = 14
        ntyp          = 5
        ecutwfc       = 60.0
        ecutrho       = 480.0
        occupations   = 'tetrahedra_opt'   ! better for DOS [PLACEHOLDER]
        nbnd          = 80                  ! [PLACEHOLDER — check with SCF nbnd]
      /
      &ELECTRONS
        conv_thr      = 1.0e-10    ! tighter for nscf [PLACEHOLDER]
        diago_full_acc= .true.
      /
      ATOMIC_SPECIES
        Hg    200.590   Hg.pbe-spd-kjpaw_psl.1.0.0.UPF
Ba    137.330   Ba.pbe-spd-kjpaw_psl.1.0.0.UPF
Cu    63.550    Cu.pbe-dn-kjpaw_psl.1.0.0.UPF
O     16.000    O.pbe-n-kjpaw_psl.1.0.0.UPF
Ca    40.080    Ca.pbe-spn-kjpaw_psl.1.0.0.UPF

      K_POINTS automatic
        16 16 8  0 0 0   ! [PLACEHOLDER — converge DOS]

      ATOMIC_POSITIONS crystal
      ! [PLACEHOLDER] copy from SCF output
        Hg    0.000000  0.000000  0.000000
Ba    0.500000  0.500000  0.185200
Ba    0.500000  0.500000  -0.185200
Ca    0.000000  0.000000  0.500000
Cu    0.500000  0.000000  0.294000
Cu    0.000000  0.500000  -0.294000
O     0.500000  0.500000  0.000000
O     0.500000  0.500000  0.000000
O     0.500000  0.000000  0.310000
O     0.000000  0.500000  0.310000
O     0.500000  0.000000  -0.310000
O     0.000000  0.500000  -0.310000
O     0.500000  0.500000  0.440000
O     0.500000  0.500000  -0.440000
