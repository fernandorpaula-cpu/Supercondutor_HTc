! projwfc.in — Hg-1212, P = 5.0 GPa (50 kbar)
! Run with: projwfc.x < projwfc.in > projwfc.out
! Output: orbital-resolved PDOS per atom (Cu-d, O-p, etc.)
!
&PROJWFC
  prefix    = 'Hg1212_P50kbar'
  outdir    = './out/'
  filpdos   = 'Hg1212_P50kbar.pdos'
  Emin      = -10.0   ! eV [PLACEHOLDER]
  Emax      =  10.0   ! eV [PLACEHOLDER]
  DeltaE    =  0.01   ! eV [PLACEHOLDER]
  degauss   = 0.005
  lsym      = .true.   ! use symmetry for orbital projection
/
